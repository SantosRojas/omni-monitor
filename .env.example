# Database connection
# Supported: sqlite, postgres, mysql, mssql
DB_CONNECTION=sqlite
DB_HOST=127.0.0.1
DB_PORT=1433
DB_DATABASE=database.db
DB_USERNAME=root
DB_PASSWORD=

# Server
MONITOR_HOST=127.0.0.1
MONITOR_PORT=9002

# JWT
JWT_SECRET=change-me-to-a-secure-random-string
JWT_EXPIRATION_HOURS=24
JWT_ISSUER=monitor

# Default admin password (used only when no users exist)
ADMIN_PASSWORD=change-me

# CORS allowed origins (comma-separated, use * for any)
CORS_ORIGINS=http://localhost:9002

# Polling interval for frontend auto-refresh (milliseconds)
POLLING_INTERVAL_MS=15000
